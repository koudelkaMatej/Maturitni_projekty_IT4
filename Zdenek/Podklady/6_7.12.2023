e = {}\n","\n","for i in range(5):\n","  jmeno = input(\"Zadejte jméno žáka: \")\n","  znamka = float(input(\"Zadejte průměr známek žáka {}: \".format(jmeno)))\n","  pole[jmeno] = znamka\n","print(\"\\n\\n\")\n","for jmeno, znamka in pole.items():\n","  print(f\"Žák jménem: {jmeno} má průměr: {znamka}\")\n","\n","prumer = sum(pole.values()) / len(pole)\n","print(f\"Průměr třídy je: {prumer}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"FRUPxw1nwOPG","executionInfo":{"status":"ok","timestamp":1701944884337,"user_tz":-60,"elapsed":21697,"user":{"displayName":"Adam Zdeněk","userId":"17096521383523157550"}},"outputId":"a3c1e795-4ea4-4c79-aa7d-a05ed7fd0ba6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Zadejte jméno žáka: a\n","Zadejte průměr známek žáka a: 1\n","Zadejte jméno žáka: b\n","Zadejte průměr známek žáka b: 5\n","Zadejte jméno žáka: c\n","Zadejte průměr známek žáka c: 6\n","Zadejte jméno žáka: d\n","Zadejte průměr známek žáka d: 1\n","Zadejte jméno žáka: e\n","Zadejte průměr známek žáka e: 1\n","\n","\n","\n","Žák jménem: a má průměr: 1.0\n","Žák jménem: b má průměr: 5.0\n","Žák jménem: c má průměr: 6.0\n","Žák jménem: d má průměr: 1.0\n","Žák jménem: e má průměr: 1.0\n","Průměr třídy je: 2.8\n"]}]},{"cell_type":"markdown","source":["Vytvořte staticky 2D pole podle vzoru: Projděte pomocí cyklu pole a vypište každou hodnotu - oddělujte jednotlivé řádky, ať to vypadá jako obdélník. Zároveň proved'te součet všech hodnot a vypočítejte průměr hodnot - ten na konci vypište."],"metadata":{"id":"jdP_ChXFt6G_"}},{"cell_type":"code","source":["pole = [[5, 4, 3, 5, 4,6], [2,3,5,4,1,7], [2,3,6,4,8,9]]\n","for i in range(len(pole)):\n","  for j in range(len(pole[i])):\n","    print(pole[i][j],end=\" \")\n","  print()\n","sume = 0\n","for i in range(len(pole)):\n","  for j in range(len(pole[i])):\n","    sume += pole[i][j]\n","prume = soucet / (len(pole) * len(pole[0]))\n","\n","print(f\"Součet všech hodnot je: {sume} a průměr je: {prume}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"TZi54x0cuZvV","executionInfo":{"status":"ok","timestamp":1702465966146,"user_tz":0,"elapsed":254,"user":{"displayName":"Adam Zdeněk","userId":"17096521383523157550"}},"outputId":"950e91c9-335a-486c-f2f5-22514de7dc0c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["5 4 3 5 4 6 \n","2 3 5 4 1 7 \n","2 3 6 4 8 9 \n","Součet všech hodnot je: 81 a průměr je: 4.5\n"]}]},{"cell_type":"code","source":["import random\n","m = 5\n","n = 5\n","pole = [[0 for _ in range(n)] for _ in range(m)]\n","for i in range(m):\n","    for j in range(n):\n","        if 0 <= i < m and 0 <= j < n:\n","            if i % 2 == 0:\n","                pole[i][j] = random.randint(5, 9)\n","            else:\n","                pole[i][j] = random.randint(0, 4)\n","\n","for radek in pole:\n","    print(*radek)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6iWfcXq1vQpM","executionInfo":{"status":"ok","timestamp":1702466441131,"user_tz":0,"elapsed":2,"user":{"displayName":"Adam Zdeněk","userId":"17096521383523157550"}},"outputId":"b334c654-0281-48a3-b37e-842ccd75c1fa"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["8 8 6 9 9\n","2 1 2 3 2\n","6 7 8 9 8\n","0 2 2 0 4\n","9 9 5 9 5\n"]}]},{"cell_type":"markdown","source":["1. řádek: „male\",,stredni\" „vetsi“ „velke\"\n","2.  řádek:,,modre\",,zlute\",,oranzove“ „cervene\"\n","3.  řádek\" „oppel\",,audi\",,bmw\",,skoda\"\n","Následně pomocí for cyklu vypište všechny hodnoty v následujícím tvaru:,,Auto znacky:<3.radek> je velikostne <2.radek> a jeho barva je: <1.radek>\"\n","Pozn. Co výpis, to konkrétní sloupec."],"metadata":{"id":"rQy4m9Ph-GTa"}},{"cell_type":"code","source":["def fce():\n","\n","  pole = [    [\"male\", \"stredni\", \"vetsi\", \"velke\"],[\"modre\", \"zlute\", \"oranzove\", \"cervene\"],[\"opel\", \"audi\", \"bmw\", \"skoda\"]]\n","\n","  for i in range(len(pole[0])):\n","     print(f\"Auto znacky: {pole[2][i]} je velikostne {pole[0][i]} a jeho barva je: {pole[1][i]}\")\n","fce()"],"metadata":{"id":"o7B0QWTC5NtQ","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1704280341381,"user_tz":0,"elapsed":209,"user":{"displayName":"Adam Zdeněk","userId":"17096521383523157550"}},"outputId":"2ca43ee1-27ba-453c-b5e7-39304554710b"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["Auto znacky: opel je velikostne male a jeho barva je: modre\n","Auto znacky: audi je velikostne stredni a jeho barva je: zlute\n","Auto znacky: bmw je velikostne vetsi a jeho barva je: oranzove\n","Auto znacky: skoda je velikostne velke a jeho barva je: cervene\n"]}]}]}